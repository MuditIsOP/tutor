# ---- Database ----
# For local development, you can omit DATABASE_URL and the app will use SQLite.
# For Supabase, set DATABASE_URL to the connection string you copy from the dashboard.
# If your deployment target is IPv4-only, prefer the Supavisor session pooler string on port 5432.
# DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ---- Deployment URLs ----
# Public base URL of the backend, used when generating uploaded file URLs.
API_PUBLIC_BASE_URL=http://127.0.0.1:8002

# Comma-separated frontend origins allowed by CORS.
# Example:
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-preview.vercel.app
CORS_ALLOWED_ORIGINS=

# ---- Groq API ----
GROQ_API_KEY=replace_with_your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# Optional override if you need a custom Groq-compatible base URL.
# GROQ_API_BASE_URL=https://api.groq.com
#
# Compatibility note:
# The backend also accepts older GROK_* variable names if you already have them
# in a local env file, but GROQ_* is the preferred naming now.

# ---- AI Runtime ----
AI_REQUEST_TIMEOUT_SECONDS=180
AI_MAX_TOKENS=400
QUIZ_MAX_TOKENS=4000

# ---- Admin Bootstrap ----
ADMIN_DEFAULT_USERNAME=Kanishk Singh
ADMIN_DEFAULT_PASSWORD=replace_with_admin_password

# Optional placeholders for future expansion:
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
# RATE_LIMIT_REQUESTS=5
# RATE_LIMIT_WINDOW_SECONDS=1
